
@{
    ViewData["Title"] = "Product Page";
}

@model IEnumerable<Item>

<div class="mt-4 mb-4">
    <table class="table-group-stripped ">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>PricePerItem</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>
                        @item.Id
                    </td>
                    <td>
                        @item.Name
                    </td>
                    <td>
                        @item.PricePerItem
                    </td>
                    <td>
                        @item.Description
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


