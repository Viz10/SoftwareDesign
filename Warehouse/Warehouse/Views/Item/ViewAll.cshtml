
@{
    ViewData["Title"] = "Products Type Page";
}

@model IEnumerable<Warehouse.Data.DTOs.ItemDTOs.ItemResponseDTO>

@{
    var rowItems = Model.Select(dto => new Dictionary<string, object>
    {
        ["Id"]=dto.Id,
        ["Name"]=dto.Name,
        ["Description"]=dto.Description??"",
        ["PricePerItem"] = dto.PricePerItem??0
    });

    var columns = new List<string>{ "Id", "Name", "Description", "PricePerItem" };

    string controller = "Item";

}

@await Html.PartialAsync("_ViewGenericTable", (controller, columns, rowItems, "Items"))

