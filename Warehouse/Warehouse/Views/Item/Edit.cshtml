@model Warehouse.Data.DTOs.ItemDTOs.ItemResponseDTO

@{

    var enumerable = new List<(string,string,string,string?)>
    {
        ("text",     "Name",         "Name",Model.Name),
        ("number",   "Price",        "PricePerItem",Model.PricePerItem?.ToString("G29", System.Globalization.CultureInfo.InvariantCulture)), /// for , -> . decial rep
        ("text",     "Description",  "Description",Model.Description),
    };
}

@await Html.PartialAsync("_ViewGenericForm", ("Item", "Edit", "post", enumerable,(int?)Model.Id,"Item edit"))


