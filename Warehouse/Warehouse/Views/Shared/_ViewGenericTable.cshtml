
@model Warehouse.Models.GenericTableModel

@{
    ViewData["Title"] = $"View All {@Model.title}";
}

<div class="mt-4 mb-4">
    <table class="table table-striped table-lg">
        <thead>
            <tr>
                @foreach (var col in Model.ColumnNames)
                {
                    <th>@col</th>
                }
            </tr> 
        </thead>
        <tbody>
            @foreach (var pair in Model.RowPairs)
            {
                <tr>
                    @foreach (var col in Model.ColumnNames)
                    {
                        <td>@pair[col]</td>
                    }
                    @if (Context.Session.GetString("AccountType") == "Seller" || Context.Session.GetString("AccountType") == "Admin")
                    {
                        <td><a asp-controller=@Model.Controller asp-action="Edit" asp-route-id="@pair["Id"]">Edit</a></td>
                        @if (Context.Session.GetString("AccountType") == "Admin")
                        {
                            <td><a asp-controller=@Model.Controller asp-action="Delete" asp-route-id="@pair["Id"]">Delete</a></td>
                        }
                    }
                    @if (Model.ExtraActions != null)
                    {
                        @foreach (var action in Model.ExtraActions)
                        {
                            <td>
                                <a asp-controller="@(action.NewController ?? Model.Controller)"
                                       asp-action="@action.Action"
                                       asp-route-id="@pair["Id"]"
                                       class="btn btn-sm btn-outline-primary">
                                    @action.Label
                                </a>
                            </td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Context.Session.GetString("AccountType") == "Seller" || Context.Session.GetString("AccountType") == "Admin"){  
<nav class="navbar navbar-expand-sm">
    <div class="navbar-collapse">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a asp-controller="@Model.Controller" asp-action="Add" class="btn btn-success">Add @Model.title</a>
            </li>
        </ul>
    </div>
</nav>
}


@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}