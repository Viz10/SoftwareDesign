

@model (string Controller,List<string> ColumnNames,IEnumerable<Dictionary<string, object>> RowPairs,string title)

@{
    ViewData["Title"] = $"View All {@Model.title}";
}

<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
        <ul class="navbar-nav flex-grow-1">
            <li class="nav-item">
                @*<a class="nav-link text-dark" asp-controller=@Model.Controller asp-action="Add"></a>*@
            </li>
        </ul>
    </div>
</nav>

<div class="mt-4 mb-4">
    <table class="table table-striped table-lg">
        <thead>
            <tr>
                @foreach (var col in Model.ColumnNames)
                {
                    <th>@col</th>
                }
            </tr> 
        </thead>
        <tbody>
            @foreach (var pair in Model.RowPairs)
            {
                <tr>
                    @foreach (var col in Model.ColumnNames)
                    {
                        <td>@pair[col]</td>
                    }
                    @*<td><a asp-controller=@Model.Controller asp-action="Delete" asp-route-id="@pair["Id"]">Delete</a></td>
                    <td><a asp-controller=@Model.Controller asp-action="Edit" asp-route-id="@pair["Id"]">Edit</a></td>*@
                </tr>
            }
        </tbody>
    </table>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}